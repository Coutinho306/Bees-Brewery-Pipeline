# ==============================================================================
# SECURITY CONFIGURATION
# ==============================================================================
# IMPORTANT: Copy this file to .env and change all default passwords!
# NEVER commit .env to git - it contains secrets

# Airflow Fernet Key (for encrypting connection passwords and variables in DB)
# Generate a new key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME_GENERATE_A_NEW_FERNET_KEY_HERE

# Database Credentials
POSTGRES_USER=airflow
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=airflow

# Airflow Web UI Admin Credentials
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Airflow Configuration
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Data Paths (for local development)
BRONZE_PATH=/opt/airflow/data/bronze
SILVER_PATH=/opt/airflow/data/silver
GOLD_PATH=/opt/airflow/data/gold

# API Configuration
BREWERY_API_BASE_URL=https://api.openbrewerydb.org/v1
BREWERY_API_PAGE_SIZE=200
BREWERY_API_MAX_RETRIES=3

# Cloud Configuration (optional, for cloud deployments)
# CLOUD_PROVIDER=aws|gcp|azure
# AWS_BUCKET_NAME=brewery-data-lake
# GCP_BUCKET_NAME=brewery-data-lake
# AZURE_STORAGE_ACCOUNT=brewerydatalake

# Alerting Configuration (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# ALERT_EMAIL=alerts@company.com

# Environment
ENVIRONMENT=local
